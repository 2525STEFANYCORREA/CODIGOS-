<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Gestión de Productos</title>

    <!-- Bootstrap -->
    <link 
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" 
        rel="stylesheet"
    >

    <!-- Archivo de estilos propio -->
    <link rel="stylesheet" href="style.css">
</head>

<body>

    <!-- =====================================================
         ESTA SECCIÓN PODRÍA CONVERTIRSE POSTERIORMENTE EN
         base.html PARA UTILIZARLA COMO PLANTILLA GENERAL.
         ===================================================== -->

    <!-- ENCABEZADO -->
    <header class="bg-primary text-white text-center py-4">
        <div class="container">
            <h1>Gestión de Productos</h1>
            <p class="mb-0">Sistema dinámico de registro de productos</p>
        </div>
    </header>

    <!-- MENÚ -->
    <!-- Esta sección también podría formar parte de base.html -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="#">Mi Proyecto</a>

            <button 
                class="navbar-toggler" 
                type="button" 
                data-bs-toggle="collapse" 
                data-bs-target="#menu"
            >
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="menu">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="#inicio">Inicio</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="#registro">Registrar</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="#productos">Productos</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- CONTENIDO PRINCIPAL -->
    <main id="inicio" class="container py-5">

        <section class="text-center mb-5">
            <h2>Registro de Productos</h2>
            <p>
                Agregue nuevos productos utilizando el formulario.
                Los datos serán mostrados dinámicamente mediante JavaScript.
            </p>
        </section>

        <!-- FORMULARIO -->
        <section id="registro" class="card shadow p-4 mb-5">

            <h3 class="mb-4">Registrar nuevo producto</h3>

            <form id="formProducto" novalidate>

                <div class="mb-3">
                    <label for="nombre" class="form-label">
                        Nombre del producto
                    </label>

                    <input 
                        type="text" 
                        class="form-control" 
                        id="nombre"
                        placeholder="Ingrese el nombre del producto"
                    >

                    <div class="invalid-feedback">
                        El nombre debe tener al menos 3 caracteres.
                    </div>
                </div>

                <div class="mb-3">
                    <label for="descripcion" class="form-label">
                        Descripción
                    </label>

                    <textarea 
                        class="form-control" 
                        id="descripcion"
                        rows="3"
                        placeholder="Ingrese una descripción"
                    ></textarea>

                    <div class="invalid-feedback">
                        La descripción debe tener al menos 10 caracteres.
                    </div>
                </div>

                <div class="mb-3">
                    <label for="categoria" class="form-label">
                        Categoría
                    </label>

                    <input 
                        type="text" 
                        class="form-control" 
                        id="categoria"
                        placeholder="Ingrese la categoría"
                    >

                    <div class="invalid-feedback">
                        La categoría debe tener al menos 3 caracteres.
                    </div>
                </div>

                <button type="submit" class="btn btn-primary">
                    Registrar producto
                </button>

            </form>
        </section>

        <!-- CONTENIDO DINÁMICO -->
        <section id="productos">

            <h3 class="text-center mb-4">
                Productos registrados
            </h3>

            <!-- Mensaje dinámico -->
            <div id="mensajeEstado" class="alert text-center"></div>

            <!-- Los productos serán generados dinámicamente -->
            <div id="contenedorProductos" class="row g-4">
            </div>

        </section>

    </main>

    <!-- PIE DE PÁGINA -->
    <!-- Esta sección podría convertirse posteriormente en parte de base.html -->
    <footer class="bg-dark text-white text-center py-4">
        <div class="container">
            <p class="mb-0">
                &copy; 2026 - Sistema de Gestión de Productos
            </p>
        </div>
    </footer>

    <!-- Bootstrap JS -->
    <script 
        src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js">
    </script>

    <!-- JavaScript propio -->
    <script src="script.js"></script>

</body>
</html>
